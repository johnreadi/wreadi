generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Modèle pour les catégories de services
model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  icon        String?
  image       String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  services    Service[]
  products    Product[]
}

// Modèle pour les services proposés
model Service {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  shortDesc   String?
  image       String?
  icon        String?
  features    String?  // JSON string pour la liste des fonctionnalités
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
}

// Modèle pour les produits/pièces détachées
model Product {
  id          String   @id @default(cuid())
  name        String
  reference   String?  @unique
  description String?
  price       Float?
  image       String?
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  brand       String?
  series      String?
  model       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  
  configurations ProductConfiguration[]
}

// Modèle pour les demandes de devis
model QuoteRequest {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String
  phone       String?
  company     String?
  subject     String
  message     String
  status      String      @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Pour les configurateurs
  configurationType String? // 'product' ou 'cable'
  configurationId   String?
}

// QuoteStatus: PENDING, IN_PROGRESS, COMPLETED, CANCELLED

// Modèle pour les messages de contact
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Modèle pour les configurations de produits (Marque -> Série -> Modèle)
model ProductConfiguration {
  id          String   @id @default(cuid())
  brand       String
  series      String
  model       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  products    Product[]
}

// Modèle pour les types de câbles
model CableType {
  id          String   @id @default(cuid())
  name        String
  description String?
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  connectors CableConnector[]
  configurations CableConfiguration[]
}

// Modèle pour les connecteurs de câbles
model CableConnector {
  id          String   @id @default(cuid())
  name        String
  type        String   // 'male', 'female', 'both'
  image       String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  cableTypeId String
  cableType   CableType @relation(fields: [cableTypeId], references: [id])
  
  configurationsAsConnector1 CableConfiguration[] @relation("Connector1")
  configurationsAsConnector2 CableConfiguration[] @relation("Connector2")
}

// Modèle pour les configurations de câbles
model CableConfiguration {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float?
  length      Int?     // Longueur en mètres
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  cableTypeId String
  cableType   CableType @relation(fields: [cableTypeId], references: [id])
  
  connector1Id String
  connector1   CableConnector @relation("Connector1", fields: [connector1Id], references: [id])
  
  connector2Id String
  connector2   CableConnector @relation("Connector2", fields: [connector2Id], references: [id])
}

// Modèle pour les utilisateurs admin
model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String   // Hashé avec bcrypt
  role      String    @default("ADMIN")
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// AdminRole: ADMIN, SUPER_ADMIN

// Modèle pour les témoignages clients
model Testimonial {
  id        String   @id @default(cuid())
  name      String
  company   String?
  content   String
  rating    Int      @default(5)
  image     String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Modèle pour les réalisations/galerie
model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  image       String
  category    String   // 'affichage-dynamique', 'holographique', etc.
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- Nouveaux modèles pour la modernisation ---

// Modèle pour les paramètres globaux (IA, PWA, etc.)
model SiteSettings {
  id                String   @id @default("default")
  siteName          String   @default("READI.FR")
  siteSlogan        String?  @default("La Compétence !")
  siteLogo          String?  // URL ou chemin vers le logo
  primaryColor      String   @default("#dc2626") // Rouge par défaut
  fontFamily        String   @default("Inter")
  baseFontSize      String   @default("16px")
  aiEnabled         Boolean  @default(true)
  aiWelcomeMessage  String?  @default("Bonjour ! Comment puis-je vous aider ?")
  aiInstructions    String?  // Instructions pour le système (prompt)
  aiModel           String   @default("gpt-4o") // Modèle par défaut
  aiApiKey          String?  // Clé API (optionnelle si gérée par env)
  aiTemperature     Float    @default(0.7)
  
  // Configuration Messagerie (SMTP & Destinataires)
  emailSmtpHost     String?
  emailSmtpPort     Int?     @default(587)
  emailSmtpUser     String?
  emailSmtpPass     String?
  emailRecipients   String?  // Liste séparée par des virgules
  emailFrom         String?  // Adresse d'envoi (ex: no-reply@readi.fr)
  
  contactEmail      String?
  contactPhone      String?
  contactAddress    String?
  contactHours      String?
  contactMapUrl     String?  // Pour l'image de la carte
  privacyPolicy     String?  // NOUVEAU: Politique de Confidentialité
  termsOfService    String?  // NOUVEAU: Conditions Générales (CGU)
  maintenanceMode   Boolean  @default(false)
  
  // Header Styling
  headerBgColor     String   @default("#ffffff")
  headerTextColor   String   @default("#1f2937")
  headerFontSize    String   @default("16px")

  // Top Bar Settings
  topBarEnabled     Boolean  @default(false)
  topBarBgColor     String   @default("#000000")
  topBarTextColor   String   @default("#ffffff")

  updatedAt         DateTime @updatedAt
}

// Modèle pour les éléments du menu
model MenuItem {
  id        String   @id @default(cuid())
  label     String
  href      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  target    String   @default("_self") // _blank, _self
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Modèle pour les éléments de la barre d'entête (Top Bar)
model TopBarItem {
  id        String   @id @default(cuid())
  type      String   // TEXT, SCROLL, IMAGE
  content   String
  settings  String?  // JSON for speed, etc.
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Modèle pour la messagerie professionnelle (Threads)
model Conversation {
  id          String    @id @default(cuid())
  subject     String?
  participantName  String
  participantEmail String
  lastMessageAt    DateTime @default(now())
  status      String    @default("OPEN") // OPEN, CLOSED, ARCHIVED
  tags        String?   // Comma separated tags
  internalNotes String? // Notes internes pour les administrateurs
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  messages    Message[]
}

// Modèle pour les messages
model Message {
  id             String       @id @default(cuid())
  content        String
  senderType     String       // 'USER' or 'ADMIN'
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  attachments    Attachment[]
}

// Modèle pour les pièces jointes
model Attachment {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())
  
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

// Modèle pour les contenus de pages (Hero, Sections, etc.)
model PageContent {
  id              String   @id @default(cuid())
  pageSlug        String   @unique // 'home', 'pieces-detachees', etc.
  heroTitle       String?
  heroSubtitle    String?
  heroDescription String?
  heroBtnText     String?
  heroBtnLink     String?
  heroImage       String?
  heroVideoUrl    String?  // Optionnel
  heroBgColor     String?  // Couleur de fond (hex/rgb)
  heroActive      Boolean  @default(true)
  
  // Paramètres de style Hero
  titleFontSize   String?  @default("4rem")
  titleFontFamily String?  @default("inherit")
  subtitleFontSize String? @default("1.25rem")
  descriptionFontSize String? @default("1.125rem")

  updatedAt       DateTime @updatedAt
  
  sections        PageSection[]
}

model PageSection {
  id            String   @id @default(cuid())
  title         String?
  subtitle      String?
  content       String?  @default("")
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  
  // Configuration Média
  mediaType     String   @default("IMAGE") // IMAGE, VIDEO, SLIDESHOW
  mediaUrl      String?  // Pour Image unique ou Vidéo
  slides        String?  // JSON string pour le slideshow: Array<{url, alt, title}>
  
  // Style & Animation
  layout        String   @default("LEFT") // LEFT, RIGHT, CENTER (image position)
  animation     String?  @default("fade") // fade, slide, scale
  ctaText       String?
  ctaLink       String?
  backgroundColor String?  // Couleur de fond de la section

  // Paramètres de police spécifiques à la section
  titleFontSize   String? @default("2.25rem")
  titleFontFamily String? @default("inherit")
  contentFontSize String? @default("1.125rem")

  pageContentId String
  pageContent   PageContent @relation(fields: [pageContentId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Modèle pour les pages d'atterrissage personnalisées (marketing)
model LandingPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String?
  heroTitle       String?
  heroSubtitle    String?
  heroImage       String?
  heroVideo       String?
  backgroundColor String?
  content         String?  // Contenu structuré (JSON ou Markdown)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Modèle pour l'Agenda
model Event {
  id              String   @id @default(cuid())
  title           String
  description     String?
  start           DateTime
  end             DateTime
  allDay          Boolean  @default(false)
  location        String?
  participantName String?  // Pour lier à un contact
  participantEmail String? // Pour lier à un contact
  color           String?  // Couleur de l'événement
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
